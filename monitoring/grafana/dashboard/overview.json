{
  "title": "HFT Platform Overview",
  "uid": "hft-overview",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "tags": ["hft", "vietnam", "platform"],
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "API Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 8, "h": 8 },
      "targets": [{
        "expr": "sum(rate(hft_api_requests_total[1m])) by (status_code)",
        "legendFormat": "HTTP {{status_code}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }
      }
    },
    {
      "id": 2,
      "title": "API P99 Latency",
      "type": "timeseries",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 8 },
      "targets": [{
        "expr": "histogram_quantile(0.99, sum(rate(hft_api_request_duration_seconds_bucket[5m])) by (le, endpoint))",
        "legendFormat": "{{endpoint}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 3,
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "sum(hft_websocket_active_connections)",
        "instant": true
      }],
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "value": 0, "color": "green" },
            { "value": 100, "color": "yellow" },
            { "value": 500, "color": "red" }
          ]}
        }
      }
    },
    {
      "id": 4,
      "title": "Kafka Consumer Lag",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
      "targets": [{
        "expr": "hft_kafka_consumer_lag_messages",
        "legendFormat": "{{topic}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "short" }
      }
    },
    {
      "id": 5,
      "title": "Model Inference Latency (P50/P99)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(hft_model_inference_duration_seconds_bucket[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} p50"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(hft_model_inference_duration_seconds_bucket[5m])) by (le, model_name))",
          "legendFormat": "{{model_name}} p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "title": "Model Directional Accuracy",
      "type": "gauge",
      "gridPos": { "x": 12, "y": 8, "w": 6, "h": 8 },
      "targets": [{
        "expr": "hft_model_directional_accuracy",
        "legendFormat": "{{model_name}} H{{horizon_days}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "thresholds": { "steps": [
            { "value": 0, "color": "red" },
            { "value": 0.50, "color": "yellow" },
            { "value": 0.55, "color": "green" }
          ]}
        }
      }
    },
    {
      "id": 7,
      "title": "Prediction Drift (PSI)",
      "type": "timeseries",
      "gridPos": { "x": 18, "y": 8, "w": 6, "h": 8 },
      "targets": [{
        "expr": "hft_model_prediction_drift",
        "legendFormat": "{{model_name}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "steps": [
            { "value": 0, "color": "green" },
            { "value": 0.2, "color": "yellow" },
            { "value": 0.4, "color": "red" }
          ]}
        }
      }
    },
    {
      "id": 8,
      "title": "Paper Portfolio P&L",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [{
        "expr": "hft_paper_portfolio_pnl_pct",
        "legendFormat": "Portfolio {{portfolio_id}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 9,
      "title": "Data Ingest Lag",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [{
        "expr": "hft_data_ingest_lag_seconds",
        "legendFormat": "{{provider}} {{data_type}}"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": { "steps": [
            { "value": 0, "color": "green" },
            { "value": 3600, "color": "yellow" },
            { "value": 7200, "color": "red" }
          ]}
        }
      }
    },
    {
      "id": 10,
      "title": "Feature Cache Hit Rate",
      "type": "stat",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "targets": [{
        "expr": "hft_feature_cache_hit_rate",
        "instant": true
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": { "steps": [
            { "value": 0, "color": "red" },
            { "value": 0.7, "color": "yellow" },
            { "value": 0.9, "color": "green" }
          ]}
        }
      }
    }
  ]
}
